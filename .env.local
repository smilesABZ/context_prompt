# Ollama Configuration
# Set the URL of your Ollama server (default: http://localhost:11434)
OLLAMA_SERVER_URL=http://localhost:11434

# Set the model name to use (default: mistral)
# Popular options: mistral, neural-chat, dolphin-mistral, llama2, etc.
OLLAMA_MODEL=gemma4:e4b

# Stable Diffusion Configuration
# Set the URL of your Stable Diffusion web UI (default: http://localhost:7860)
#SD_SERVER_URL=http://localhost:7865
#SD_SERVER_URL=http://localhost:7865
# Make sure to enable API access in the web UI settings
#SD_SERVER_URL=http://localhost:7865

SD_SERVER_URL=http://localhost:11434
